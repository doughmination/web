# ==============================================================================
# PluralKit
# ==============================================================================

# PluralKit system token (from `pk;token` in Discord)
SYSTEM_TOKEN=

# How long (seconds) to cache PluralKit API responses. Default: 30
CACHE_TTL=30

# ==============================================================================
# Authentication
# ==============================================================================

# Secret used to sign/verify JWTs. Generate something long and random —
# e.g. `openssl rand -hex 32`. There is a hardcoded fallback in code, but
# do NOT rely on it in production.
JWT_SECRET=

# Cloudflare Turnstile secret key, used to verify login/signup challenges.
DOUGH_TURNSILE_SECRET=

# ==============================================================================
# Initial admin/owner account
# Only used on first boot, when no users.json exists yet.
# ==============================================================================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Administrator

# ==============================================================================
# Misc
# ==============================================================================

# Public base URL of this API, used to build avatar URLs etc.
BASE_URL=https://doughmination.co.uk

# Port the HTTP server listens on. Default: 5000
PORT=5000

# Optional comma-separated list of static battery API keys. If unset, a
# key is auto-generated on first boot and persisted to
# dough-data/battery_access_key.json.
# BATTERY_API_KEYS=
