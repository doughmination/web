  "description": "Doughmination System API - Plural system tracker and management API",
  "license": "ESAL-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "bun --watch src/main.ts",
