    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cookie": "^2.0.0",
    "cors": "^2.8.6",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "sharp": "^0.35.0",
    "ws": "^8.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0"
