# --- Shared Data ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
ADMIN_DISPLAY_NAME=Administrator

# --- Doughmination System Configuration ---
SYSTEM_TOKEN=your_pluralkit_token
PORT=5000
JWT_SECRET=your_secure_random_string
CACHE_TTL=30
TURNSILE_SECRET=your_secret_key_from_cloudflare

# --- Mailbox ---
RESEND_API_KEY=re_your_key_here
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Seed list of send-from addresses (comma-separated). On first run this seeds
# data/settings.json; after that the Settings page is the source of truth.
# Each domain must be verified in Resend. Optional display name supported:
#   SEND_FROM=Admin <admin@doughmination.uk>, you@yourdomain.com
SEND_FROM=you@yourdomain.com
MAIL_PORT=4040
DATA_DIR=./data

# --- Web Push (VAPID) ---
# Generate a pair with:  npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL identifying you.
# Required for the mailbox's "Enable notifications" toggle to work — if these
# are missing, push silently reports "not configured" instead of erroring.
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:you@yourdomain.com